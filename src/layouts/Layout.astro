---
interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = 'mycoach — Training Platform for Serious Endurance Athletes',
  description = 'PMC charts, AI coaching, strength tracking, and nutrition — all in one app. Built for cyclists and runners. Free tier available.',
  ogImage = '/mycoach-landing/og-image.png',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      "name": "mycoach",
      "description": description,
      "applicationCategory": "SportsApplication",
      "operatingSystem": "Web",
      "offers": [
        {
          "@type": "Offer",
          "name": "Free",
          "price": "0",
          "priceCurrency": "EUR"
        },
        {
          "@type": "Offer",
          "name": "Athlete",
          "price": "10",
          "priceCurrency": "EUR"
        },
        {
          "@type": "Offer",
          "name": "Pro",
          "price": "19",
          "priceCurrency": "EUR"
        }
      ]
    })} />

    <!-- Favicon placeholder -->
    <link rel="icon" type="image/svg+xml" href="/mycoach-landing/favicon.svg" />

    <!-- Umami Analytics -->
    <script defer src="https://umami.kilianmbg.dev/script.js" data-website-id="1c567f1f-f042-470e-bca7-7c54ae706966"></script>

    <slot name="head" />
  </head>
  <body>
    <slot />
  </body>
</html>
